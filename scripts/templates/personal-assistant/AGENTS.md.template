    "name": "{{AGENT_NAME}}",
    "version": "1.0.0",
    "type": "Agent底层框架规则",
    "memory_system": "v2.0 分层记忆系统"
  },
  "session_startup": {
    "required_read_files": [
      "IDENTITY.md",
      "SOUL.md",
      "USER.md",
