# TOOLS.md - {{AGENT_NAME}} 的本地环境与工具配置

> ⚠️ 本文件采用 XML 优先结构，符合 openclaw-core-files-architect v2.0 标准
> 🔒 严禁在此文件直接写入明文密码或 API Key！

```xml
<tool_notes>
  <environment>
    <os>{{OS}}</os>
    <workspace>{{WORKSPACE_PATH}}</workspace>
    <timezone>Asia/Shanghai</timezone>
  </environment>

  <credentials_pointers>
    <pointer type="飞书 Bot Secret">~/.openclaw/openclaw.json</pointer>
    <pointer type="其他 API Key">LanceDB (category=fact, importance=0.95)</pointer>
  </credentials_pointers>

  <preferred_tools_by_task>
    <tool task="记忆检索">lancedb-query</tool>
    <tool task="记忆文件管理">memory-manager</tool>
    <tool task="网络搜索">searxng-web-search</tool>
    <tool task="浏览器自动化">agent-browser</tool>
  </preferred_tools_by_task>

  <installed_skills>
{{SKILLS_LIST}}
  </installed_skills>

  <local_traps>
{{LOCAL_TRAPS}}
    <trap id="powershell">复杂命令必须写入 .ps1 脚本执行</trap>
    <trap id="feishu-message">优先使用 message 工具（机器人身份）发送消息</trap>
    <trap id="browser-cleanup">浏览器闲置 30 分钟自动杀进程</trap>
  </local_traps>

  <platform_constraints>
    <constraint platform="feishu" type="群聊">仅被@或能纠正关键错误时发言</constraint>
    <constraint platform="feishu" type="私聊">发送图片、文件、重要通知时使用 message 工具</constraint>
    <constraint platform="feishu" type="表格消息">不适合长文</constraint>
  </platform_constraints>

  <self_hosted_services>
    <service name="SearXNG" port="8888" start="cd ~/.openclaw/searxng && ./start_searxng.cmd" />
  </self_hosted_services>
</tool_notes>
```

